FROM node:20-alpine

# Install dependencies
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm ci

# Expose port
EXPOSE 3000

# Start development server
# Note: The rest of the code will be mounted as a volume
CMD ["npm", "run", "dev"]
