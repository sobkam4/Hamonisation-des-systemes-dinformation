# -----------------------------------------------------------------------------
# Base de données (production / Docker)
# Soit POSTGRES_* (comme docker-compose.yml), soit DATABASE_URL (backend/docker-compose.yml)
# -----------------------------------------------------------------------------
POSTGRES_DB=location_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://postgres:your-secure-password-here@db:5432/location_erp

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=0
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,backend
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Origines CSRF (Django 4+) ; si vide, on réutilise CORS_ALLOWED_ORIGINS
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# Frontend (URL appelée par le navigateur — pas l’URL interne Docker)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
# Si le port 3000 est déjà pris sur l’hôte (ex. autre Next.js) :
# FRONTEND_PUBLISH_PORT=3001

# -----------------------------------------------------------------------------
# MinIO (docker-compose.prod.yml — MINIO_ROOT_PASSWORD est obligatoire)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-password
# Ports exposés hôte (optionnel)
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Stockage S3 / MinIO côté Django
# Avec MinIO fourni par compose : même identifiants que ci-dessus pour les clés AWS.
# -----------------------------------------------------------------------------
USE_S3=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change-me-strong-password
AWS_STORAGE_BUCKET_NAME=location-erp
# URL interne pour boto3 (résolution DNS Docker)
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
# Hôte:port vus par le navigateur pour les URLs médias/fichiers (ex. localhost:9000 en local)
AWS_S3_CUSTOM_DOMAIN=localhost:9000
# true si endpoint HTTPS réel ; sinon false pour MinIO HTTP local
# AWS_S3_VERIFY=false

# -----------------------------------------------------------------------------
# Nginx (production)
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80

# -----------------------------------------------------------------------------
# Gunicorn / Celery (optionnel)
# -----------------------------------------------------------------------------
# GUNICORN_WORKERS=3
# CELERY_WORKERS=4

# -----------------------------------------------------------------------------
# Email (optionnel)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
